ONEFS_ENDPOINT=your-onefs-cluster.example.com:8080
ONEFS_USERNAME=your-readonly-username
ONEFS_PASSWORD=your-password
# Alternatively, read the password from a file (takes precedence over ONEFS_PASSWORD).
# Keeps the secret out of the process environment / `docker inspect`.
# ONEFS_PASSWORD_FILE=/run/secrets/onefs_password
ONEFS_INSECURE=true
POLL_INTERVAL_SECONDS=30
ALL_STATS_ENABLED=true
ALL_POLL_INTERVAL_SECONDS=300
LISTEN_PORT=9684
